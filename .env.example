# NIRA works without environment variables in deterministic offline mode.
NIRA_LOCAL_MODEL_ENABLED=false
NIRA_LLAMA_BASE_URL=http://127.0.0.1:8080
NIRA_LLAMA_MODEL=
NIRA_MANAGE_LLAMA_SERVER=false
NIRA_LLAMA_DIR=
NIRA_LLAMA_MODEL_PATH=
NIRA_WEB_RESEARCH_ENABLED=false
NIRA_ENABLE_VOICE=false
NIRA_ENABLE_OVERLAY=false
NIRA_INTERACTION_LOGGING_ENABLED=false

# Prefer --state-dir for demos/tests to keep local state isolated.
# Never put tokens, passwords, private URLs, or customer data here.
